# Environment variables for Bus Route Optimizer
# Copy this file to .env and update with actual values

# API Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here
REACT_APP_GTFS_ENDPOINT=https://transit-api.example.com
REACT_APP_ENVIRONMENT=development

# Auth Configuration
REACT_APP_AUTH0_DOMAIN=your-domain.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your_client_id_here

# Feature Flags
REACT_APP_ENABLE_BETA_FEATURES=false
REACT_APP_ENABLE_ANALYTICS=true

# Analytics
REACT_APP_DATADOG_APPLICATION_ID=your_app_id
REACT_APP_DATADOG_CLIENT_TOKEN=your_client_token
